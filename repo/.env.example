# Copy this file to .env and fill in values before running
# No external SaaS or network dependencies — all values are local

DATABASE_URL=postgres://venue:venue@db:5432/venue_ops

# Server
APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=8080
APP__SERVER__WORKERS=4

# Encryption key for sensitive fields (wallet_balance, procurement_cost)
# Must be exactly 64 hex characters (32 bytes)
APP__ENCRYPTION__KEY_HEX=<generate with: openssl rand -hex 32>

# JWT signing secret (any long random string)
APP__JWT__SECRET=<generate with: openssl rand -base64 48>
APP__JWT__EXPIRY_SECONDS=86400

# Background job intervals
APP__JOBS__HOLD_EXPIRY_INTERVAL_SECS=60
APP__JOBS__PAYMENT_TIMEOUT_INTERVAL_SECS=60
APP__JOBS__REMINDER_INTERVAL_SECS=3600
APP__JOBS__DND_RESOLVE_INTERVAL_SECS=300
APP__JOBS__ZERO_QTY_INTERVAL_SECS=600
APP__JOBS__TIER_RECALC_HOUR=2
APP__JOBS__BACKUP_HOUR=3

# Booking hold timeout (minutes)
APP__BOOKING__HOLD_TIMEOUT_MINUTES=15
# Inventory deduction strategy: "hold" (default) or "immediate"
APP__BOOKING__INVENTORY_STRATEGY=hold

# Payment intent timeout (minutes)
APP__PAYMENT__INTENT_TIMEOUT_MINUTES=30

# Do Not Disturb window (local time hours, 0-23)
APP__DND__START_HOUR=21
APP__DND__END_HOUR=7

# Backup config
APP__BACKUP__DIR=./storage/backups
# UTC offset in minutes for local-time backup scheduling (e.g., -300 for US Eastern, 60 for CET)
APP__BACKUP__TIMEZONE_OFFSET_MINUTES=0
APP__STORAGE__RECONCILIATION_DIR=./storage/reconciliation_imports
APP__STORAGE__ATTACHMENTS_DIR=./storage/attachments
APP__STORAGE__MAX_UPLOAD_BYTES=10485760

# Notification channel allow-list. Comma-separated subset of:
# in_app, email, sms, push. Channels not listed here are rejected at the API
# layer (template create + member preference update) so a real provider must
# be wired before users can route notifications through it. Default: in_app.
APP__NOTIFICATIONS__ENABLED_CHANNELS=in_app

# Demo-user seeding (dev/reviewer profile ONLY — MUST be false in production).
# When true, the app inserts the 7 role-mapped demo accounts from the README
# (admin, ops, finance, asset_mgr, evaluator, reviewer, member) idempotently
# on startup, using APP__BOOTSTRAP__DEMO_PASSWORD as the shared password. This
# makes `docker-compose up` a zero-manual-setup bring-up for reviewers.
APP__BOOTSTRAP__SEED_DEMO_USERS=true
APP__BOOTSTRAP__DEMO_PASSWORD=Test1234!

# Logging
RUST_LOG=info
